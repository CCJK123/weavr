# Weavr MVP environment variables.
# Copy to .env for local development. Do not commit real secrets.
# The profile page renders without any of these configured; only the routes
# that need a credential read it lazily via getRequiredServerEnv.

# Base URL of the running app. Used to build provider redirect URIs.
# Local dev: http://localhost:5173
# Stable HTTPS is required for real X OAuth callbacks and Telegram webhooks.
APP_URL=http://localhost:5173

# --- X (Twitter) OAuth 2.0 with PKCE ---------------------------------------
# Create an app at https://developer.x.com/ and set the callback URL to
# ${APP_URL}/api/auth/x/callback.
X_CLIENT_ID=
X_CLIENT_SECRET=
# Must equal ${APP_URL}/api/auth/x/callback.
X_REDIRECT_URI=http://localhost:5173/api/auth/x/callback

# --- Telegram Login / OIDC (identity only) ---------------------------------
# Configure at https://my.telegram.org/apps and set the redirect URI to
# ${APP_URL}/api/auth/telegram/callback.
TELEGRAM_OIDC_CLIENT_ID=
TELEGRAM_OIDC_CLIENT_SECRET=
# Must equal ${APP_URL}/api/auth/telegram/callback.
TELEGRAM_OIDC_REDIRECT_URI=http://localhost:5173/api/auth/telegram/callback

# --- Telegram Bot ingestion ------------------------------------------------
# Create a bot via @BotFather. Set the webhook to
# ${APP_URL}/api/webhooks/telegram with this secret token.
TELEGRAM_BOT_TOKEN=
# Arbitrary secret passed via the X-Telegram-Bot-Api-Secret-Token header.
TELEGRAM_WEBHOOK_SECRET_TOKEN=

# Optional: Telegram channel id (e.g. -1001234567890) whose channel posts
# the bot should ingest. If unset, channel posts are ignored with a notice.
TELEGRAM_DEMO_CHANNEL_ID=
